section.product-detail-3(class="section-py")
	.container 
		h2(class="heading-4 text-center  mb-base") Sản phẩm gợi ý
		.swiper-column-auto(class="relative autoplay swiper-loop")
			.swiper 
				.swiper-wrapper
					-for(var i = 0; i < 6; i++) 
						.swiper-slide 
							+ProductItem() 
			.wrap-button-slide
				.btn.btn-sw-1.btn-prev
				.btn.btn-sw-1.btn-next
section.product-detail-4(class="section-py bg-Utility-gray-50")
	.container 
		h2(class="heading-4 text-center mb-base") Sản phẩm liên quan
