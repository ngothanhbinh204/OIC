section.section-change-big-image.title-fade-left(tab-wrapper="parent" tab-mode="mouseenter" class="bg-black relative")
	- var loops = 4;
	.images(class="absolute inset-0")
		-for(i=0;i<loops;i++)
			a(tab-content="parent" tab-content-value=`${i+1}` no-animation class="absolute inset-0 [&_img]:size-full [&_img]:object-cover transition-all duration-500")
				+PugImg()
	.container-fluid.relative(class="z-3")
		.big-wrapper.relative(class="flex items-center lg:flex-row flex-col")
			h2.bottom-title(class="text-[1.8rem] sm:text-[2.4rem] md:text-[3.2rem] lg:text-[4.2rem] xl:rem:text-[96px] uppercase font-bold font-heading overflow-hidden") Vì sao The 350F được tin chọn?
			.wrapper(class="flex items-center justify-between gap-x-3 gap-y-6 w-full lg:flex-nowrap flex-wrap")
				.list-contents(class="bg-Primary-1 text-primary-1 pl-9 pr-23 pb-10 pt-10 md:pt-20 lg:pt-30 w-full relative")
					-for(i=0;i<loops;i++)
						.box-content(tab-content="parent" tab-content-value=`${i+1}`)
							h3.sub-block-title(class="animate-title" animate-title="fade-up") Nhân sự #{i+1}
							.title(class="text-[2.4rem]") chuyên môn cao
							.description(class="mt-6 xl:rem:pr-[46px]")  #{i+1} Dày dạn kinh nghiệm & am hiểu về sản phẩm
				nav
					ul(class="lg:space-y-5")
						-for(i=0;i<loops;i++)
							li(tab-item="parent" tab-item-value=`${i+1}` class="cursor-pointer item")
								.item-wrapper(class="text-white flex justify-end items-center gap-5 transition-all duration-500 opacity-50 lg:opacity-30")
									span(class="font-bold") 0#{i+1}
