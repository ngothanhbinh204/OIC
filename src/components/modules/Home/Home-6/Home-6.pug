section.home-6(class="section-py !pt-0" tab-wrapper="parent" tab-mode="mouseenter")
	.container-fluid
		.wrap-tabslet(data-toggle="tabslet")
			.wrap-heading(class="flex md:flex-row gap-base flex-col items-center justify-between")
				+HeadingTitle("Media").text-Primary-1
				ul.tabslet-tab.nav-primary
					li.active
						a(href="#tab1") All news
					li
						a(href="#tab2") News
					li
						a(href="#") Insights
					li
						a(href="#") Thought Leadership
			.tabslet-content.active#tab1
				.wrapper-main(data-media-list)
					-for(i=0;i<4;i++)
						.item.media-item-wrapper(tab-item="parent" tab-item-value=`${i+1}` class="grid lg:grid-cols-[calc(1240/1600*100%)_1fr] grid-cols-1 gap-base")
							.wrap-content(class="grid items-center xl:grid-cols-[calc(205/1240*100%)_1fr] grid-cols-1 xl:rem:gap-[115px]")
								.month Feb.06
								.infos 
