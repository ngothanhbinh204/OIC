										p Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s, when an unknown ...
									.icon(class="text-xl")
										i.fa-solid.fa-plus
							.wrap-image 
								a(href="#" class="img-ratio rounded-2 ratio:pt-[240_320]" tab-content="parent" tab-content-value=`${i+1}`)  
									+PugImg()
				.button-more(data-load-more-media class="rem:mt-[31px] xl:rem:ml-[320px]") 
					button(class="btn btn-primary style-default")
						span Show More
						.icon
