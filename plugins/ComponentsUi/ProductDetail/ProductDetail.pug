section.product-detail-1(class="section-py")
	.container
		.product-detail-main(class="flex flex-col lg:flex-row xl:gap-16 gap-base")
			.col-left(class="xl:rem:max-w-[805px] lg:w-2/4 w-full")
				.wrapper(class="grid md:grid-cols-[calc(118/805*100%)_1fr] grid-cols-[calc(120/805*100%)_1fr] gap-[calc(20/805*100%)]")
					.thumb.relative
						.relative(class="w-full h-full")
							.swiper
								.swiper-wrapper
									-for(i=0;i<6;i++)
										.swiper-slide
											.img
												a(class="img-ratio") 
													+PugImg()
						.wrap-button-slide.arrow-vertical
							.button-prev
							.button-next
					.main
						.swiper
							.swiper-wrapper
								-for(i=0;i<6;i++)
									.swiper-slide
										.img
											a(class="img-ratio rounded-4")
												+PugImg() 
			.col-right(class="flex-1")
				h2(class="rem:text-[32px] font-bold mb-3") Ba Chỉ Bò Mỹ 500G
				.code-product 
					p 
						| Mã sản phẩm: 
						br
						span 780USFE HL
				.format-content(class="mt-4")
					-for(i=0;i<3;i++)
						p Ba chỉ bò mỹ (hay còn gọi là Ba rọi bò mỹ - Short Plate )  là phần thịt bụng của con bò, Được KIWIFOOD nhập khẩu trực tiếp Nguyên Container từ Mỹ về Việt Nam
					.info-product
						table 
							-for(i=0;i<5;i++)
								tr 
									td Tình trạng:
									td.parameter Còn hàng.
				.filters 
					.label Theo dung tích:
					.value 
						ul 							
							li.active
								span 500gr
							li 
								span 500gr
							li 
								span 500gr
							li 
								span 500gr
							li 
								span 500gr
				.price-product 
					.label Giá sản phẩm:
					.price 
						bdi 15.000.000đ
				.wrap-bottom 
					.button-contact(class="flex items-center gap-6 whitespace-nowrap")
						a(href="#form-contact-product" class="btn btn-contact" data-fancybox) 
							span Liên hệ để nhận tư vấn
							.icon 
								<i class="fa-regular fa-pen-to-square"></i>
						a(href="#" class="btn btn-location") 
							span Điểm bán gần bạn
							.icon 
								<i class="fa-regular fa-store"></i>
					.commercial(class="flex gap-4") 	
						.label Sàn thương mại:
						.commercial-img(class="flex gap-2 flex-wrap")
							-for(i=0;i<8;i++)
								img(src="./img/bachhoaxanh.png", alt="")
					.share(class="flex items-center gap-3") 
						.label Share:
						.social 
							a(href="#") 
								<i class="fa-brands fa-facebook-f"></i>
